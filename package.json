{
  "scripts": {
    "dev": "tsx server.ts",
    "dev:nodemon": "nodemon server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "nodemonConfig": {
    "watch": [
      "server.ts",
      "tsconfig.json"
    ],
    "ext": "ts,json",
    "execMap": {
      "ts": "tsx"
    }
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "google-auth-library": "^9.15.1",
    "jose-cjs": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.1",
    "tsx": "^4.21.0",
    "typescript": "^7.0.2"
  }
}
